(version 1)
(deny default)
(allow process*)
(allow sysctl-read)
(allow file-read-metadata file-test-existence)
(allow file-read-data (literal "/"))
(allow file-read* file-write* (literal "/dev/null"))
(allow file-read* file-test-existence file-map-executable (extension "com.apple.app-sandbox.read"))
(allow file-read* file-test-existence file-map-executable (extension "com.apple.app-sandbox.read-write"))
(allow file-write* (extension "com.apple.app-sandbox.read-write"))
(deny network*)
