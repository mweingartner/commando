{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MPD Routing Evidence v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "suite_digest", "rubric_digest", "generated_unix_secs", "minimum_samples", "samples"],
  "properties": {
    "schema": {"const": "routing-evidence-v1"},
    "suite_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "rubric_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "generated_unix_secs": {"type": "integer", "minimum": 0},
    "minimum_samples": {"type": "integer", "minimum": 1, "maximum": 4096},
    "samples": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4096,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["harness", "persona", "model", "task_id", "blind", "seed", "quality_bps", "escaped_defects", "rework_steps", "latency_ms", "tokens", "cost_micros", "currency"],
        "properties": {
          "harness": {"type": "string", "minLength": 1, "maxLength": 96},
          "persona": {"type": "string", "minLength": 1, "maxLength": 96},
          "model": {"type": "string", "minLength": 1, "maxLength": 96},
          "task_id": {"type": "string", "minLength": 1, "maxLength": 160},
          "blind": {"const": true},
          "seed": {"type": "integer", "minimum": 0},
          "quality_bps": {"type": "integer", "minimum": 0, "maximum": 10000},
          "escaped_defects": {"type": "integer", "minimum": 0},
          "rework_steps": {"type": "integer", "minimum": 0},
          "latency_ms": {"type": "integer", "minimum": 0},
          "tokens": {"type": "integer", "minimum": 0},
          "cost_micros": {"type": "integer", "minimum": 0},
          "currency": {"type": "string", "pattern": "^[A-Z]{3}$"}
        }
      }
    }
  }
}
