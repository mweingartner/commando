#!/bin/sh
# Reviewable source only. Activation installs approved clone-private wrappers;
# this file remains a fail-closed fallback for explicit local hooksPath use.
if ! command -v mpd >/dev/null 2>&1; then
  echo "mpd: pre-commit blocked; approved coordinator is unavailable" >&2
  exit 1
fi
exec mpd hook pre-commit
